    {
      "id": 120,
      "title": "System Health",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 56,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 21,
      "title": "CPU Usage (%)",
      "description": "Overall CPU utilisation across all cores (100% = 1 core fully busy).",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 57,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Memory Usage",
      "description": "RAM used per node. macOS: active+wired. Linux Pi: MemTotal-MemAvailable.",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 57,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(node_memory_active_bytes{job=\"node\",node=\"master\"} + node_memory_wired_bytes{job=\"node\",node=\"master\"}) / 1024 / 1024 / 1024",
          "legendFormat": "master used GB"
        },
        {
          "expr": "node_memory_total_bytes{job=\"node\",node=\"master\"} / 1024 / 1024 / 1024",
          "legendFormat": "master total GB"
        },
        {
          "expr": "(node_memory_MemTotal_bytes{job=\"node\",node!=\"master\"} - node_memory_MemAvailable_bytes{job=\"node\",node!=\"master\"}) / 1024 / 1024 / 1024",
          "legendFormat": "{{node}} used GB"
        },
        {
          "expr": "node_memory_MemTotal_bytes{job=\"node\",node!=\"master\"} / 1024 / 1024 / 1024",
          "legendFormat": "{{node}} total GB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 23,
      "title": "Disk Free \u2014 / (root)",
      "description": "Available bytes on the root APFS volume.",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 57,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\"} / 1024 / 1024 / 1024",
          "legendFormat": "free GB"
        },
        {
          "expr": "node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\"} / 1024 / 1024 / 1024",
          "legendFormat": "total GB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 24,
      "title": "Disk I/O (MB/s)",
      "description": "Disk read/write throughput. master=disk0 (NVMe), Pi workers=mmcblk0 (SD card).",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 64,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"node\",device=\"disk0\"}[1m]) / 1024 / 1024",
          "legendFormat": "master read MB/s"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"node\",device=\"disk0\"}[1m]) / 1024 / 1024",
          "legendFormat": "master write MB/s"
        },
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"node\",device=\"mmcblk0\"}[1m]) / 1024 / 1024",
          "legendFormat": "{{node}} read MB/s"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"node\",device=\"mmcblk0\"}[1m]) / 1024 / 1024",
          "legendFormat": "{{node}} write MB/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 25,
      "title": "System Load",
      "description": "1 / 5 / 15 minute load average.",
      "type": "timeseries",
      "gridPos": {
        "x": 8,
        "y": 64,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_load1{job=\"node\"}",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5{job=\"node\"}",
          "legendFormat": "5m"
        },
        {
          "expr": "node_load15{job=\"node\"}",
          "legendFormat": "15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 26,
      "title": "Swap Used",
      "description": "Swap usage per node. macOS: swap_used + compressed. Linux Pi: SwapTotal - SwapFree.",
      "type": "timeseries",
      "gridPos": {
        "x": 16,
        "y": 64,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(node_memory_swap_used_bytes{job=\"node\",node=\"master\"} + node_memory_compressed_bytes{job=\"node\",node=\"master\"}) / 1024 / 1024",
          "legendFormat": "master swap+compressed MB"
        },
        {
          "expr": "(node_memory_SwapTotal_bytes{job=\"node\",node!=\"master\"} - node_memory_SwapFree_bytes{job=\"node\",node!=\"master\"}) / 1024 / 1024",
          "legendFormat": "{{node}} swap used MB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
