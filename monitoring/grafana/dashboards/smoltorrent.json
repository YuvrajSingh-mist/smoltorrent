{
  "uid": "smoltorrent",
  "title": "Server",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timezone": "browser",
  "panels": [
    {
      "id": 100,
      "title": "Server",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 101,
      "title": "Server Uptime (hours)",
      "description": "Hours since last OS boot. Drops to 0 on reboot.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(time() - node_boot_time_seconds{job=\"node\",node=\"master\"}) / 3600",
          "legendFormat": "uptime"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "drawStyle": "line",
            "axisLabel": "uptime (h)"
          },
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 102,
      "title": "API Process Uptime (hours)",
      "description": "Hours since API process last started. Drops to 0 on each restart.",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(time() - smoltorrent_process_start_time_seconds{job=\"smoltorrent-api\"}) / 3600",
          "legendFormat": "API uptime"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "drawStyle": "line",
            "axisLabel": "uptime (h)"
          },
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 103,
      "title": "Server Health",
      "description": "API up = Prometheus can scrape port 8000; Watcher up = port 8001 reachable. Both must be 1 for the cluster to be fully operational.",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 12,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"smoltorrent-api\"}",
          "legendFormat": "API"
        },
        {
          "expr": "up{job=\"smoltorrent-watcher\"}",
          "legendFormat": "Watcher"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "NO DATA"
        }
      }
    },
    {
      "id": 104,
      "title": "Server Last Boot",
      "description": "Boot timestamp for the coordinator \u2014 flat line jumps on reboot.",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 7,
        "w": 12,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_boot_time_seconds{job=\"node\",node=\"master\"} * 1000",
          "legendFormat": "master"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "drawStyle": "line"
          },
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 110,
      "title": "Store",
      "type": "row",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 1
      }
    },
    {
      "id": 301,
      "title": "Store Bandwidth (Mbps)",
      "description": "Bytes/s flowing from coordinator \u2192 Pi workers during /store-shard. Idle = 0.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(smoltorrent_bytes_sent_total{job='smoltorrent-api'}[1m]) * 8 / 1024 / 1024",
          "legendFormat": "send Mbps",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "id": 302,
      "title": "Store Wall-Clock Time (s)",
      "description": "End-to-end duration of each /store-shard call. p50 = typical; p95/p99 = outliers.",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 13,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(smoltorrent_store_wall_seconds_bucket[10m]))",
          "legendFormat": "p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.95, rate(smoltorrent_store_wall_seconds_bucket[10m]))",
          "legendFormat": "p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.99, rate(smoltorrent_store_wall_seconds_bucket[10m]))",
          "legendFormat": "p99",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "drawStyle": "line"
          }
        }
      }
    },
    {
      "id": 303,
      "title": "Per-Pi Bytes Received \u2014 store (MB)",
      "description": "Cumulative bytes each Pi worker received from the coordinator. All lines should rise together; a flat line means that Pi missed its shard.",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "worker_bytes_recv_total{job='worker-metrics'} / 1024 / 1024",
          "legendFormat": "{{node}}",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
