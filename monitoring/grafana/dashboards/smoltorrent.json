      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(worker_store_duration_seconds_bucket{job='worker-metrics'}[5m]))",
          "legendFormat": "{{node}} p50",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        },
        {
          "expr": "histogram_quantile(0.95, rate(worker_store_duration_seconds_bucket{job='worker-metrics'}[5m]))",
          "legendFormat": "{{node}} p95",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          }
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
