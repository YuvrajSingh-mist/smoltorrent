    {
      "id": 304,
      "title": "Per-Pi Store Duration (s)",
      "description": "Time each Pi took to write its shard to disk. p50/p95 per node \u2014 rising gap means one Pi is slower (hot SD card, network jitter).",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
