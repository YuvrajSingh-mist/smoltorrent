{
  "uid": "smoltorrent",
  "title": "Server",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "Server",
      "type": "row",
      "gridPos": {
        "y": 0,
        "x": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 30,
      "title": "Operation Wall-Clock Time (seconds)",
      "description": "End-to-end wall time for each /store-shard and /gather-shards call. p50 = typical run; p95/p99 = slowest outliers. Rising values indicate network congestion or slow workers.",
      "type": "timeseries",
      "gridPos": {
        "y": 7,
        "x": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(smoltorrent_store_wall_seconds_bucket[10m]))",
          "legendFormat": "store p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(smoltorrent_store_wall_seconds_bucket[10m]))",
          "legendFormat": "store p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(smoltorrent_store_wall_seconds_bucket[10m]))",
          "legendFormat": "store p99"
        },
        {
          "expr": "histogram_quantile(0.50, rate(smoltorrent_gather_wall_seconds_bucket[10m]))",
          "legendFormat": "gather p50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(smoltorrent_gather_wall_seconds_bucket[10m]))",
          "legendFormat": "gather p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(smoltorrent_gather_wall_seconds_bucket[10m]))",
          "legendFormat": "gather p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2,
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "store p50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "gather p50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "green"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 101,
      "title": "Server Uptime (hours)",
      "description": "Hours since last OS boot. Drops to 0 on reboot.",
      "type": "timeseries",
      "gridPos": {
        "y": 1,
        "x": 0,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(time() - node_boot_time_seconds{job=\"node\",node=\"master\"}) / 3600",
          "legendFormat": "uptime"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "drawStyle": "line",
            "axisLabel": "uptime (h)"
          },
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 102,
      "title": "API Process Uptime (hours)",
      "description": "Hours since API process last started. Drops to 0 on each restart.",
      "type": "timeseries",
      "gridPos": {
        "y": 1,
        "x": 12,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(time() - process_start_time_seconds{job=\"smoltorrent-api\"}) / 3600",
          "legendFormat": "API uptime"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "h",
          "min": 0,
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 0,
            "spanNulls": true,
            "drawStyle": "line",
            "axisLabel": "uptime (h)"
          },
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 104,
      "title": "Server Last Boot",
      "description": "Boot timestamp for the coordinator \u2014 flat line jumps on reboot.",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 13
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_boot_time_seconds{job=\"node\",node=\"master\"} * 1000",
          "legendFormat": "master"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "single"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsLocal",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": true,
            "drawStyle": "line"
          },
          "noValue": "N/A"
        }
      }
    },
    {
      "id": 1,
      "title": "Bandwidth (Mbps)",
      "description": "Send and receive bandwidth as reported directly by the API. A curve that starts fast and decelerates exponentially = O(n\u00b2) copying bug.",
      "type": "timeseries",
      "gridPos": {
        "y": 21,
        "x": 0,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smoltorrent_send_bandwidth_mbps",
          "legendFormat": "send Mbps"
        },
        {
          "expr": "smoltorrent_recv_bandwidth_mbps",
          "legendFormat": "recv Mbps"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Transfer Duration Percentiles (seconds)",
      "description": "p50 / p90 / p95 / p99 send and recv duration. Rising tail = slow worker or network issue.",
      "type": "timeseries",
      "gridPos": {
        "y": 7,
        "x": 12,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(smoltorrent_send_duration_seconds_bucket[5m]))",
          "legendFormat": "send p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(smoltorrent_send_duration_seconds_bucket[5m]))",
          "legendFormat": "send p90"
        },
        {
          "expr": "histogram_quantile(0.95, rate(smoltorrent_send_duration_seconds_bucket[5m]))",
          "legendFormat": "send p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(smoltorrent_send_duration_seconds_bucket[5m]))",
          "legendFormat": "send p99"
        },
        {
          "expr": "histogram_quantile(0.50, rate(smoltorrent_recv_duration_seconds_bucket[5m]))",
          "legendFormat": "recv p50"
        },
        {
          "expr": "histogram_quantile(0.90, rate(smoltorrent_recv_duration_seconds_bucket[5m]))",
          "legendFormat": "recv p90"
        },
        {
          "expr": "histogram_quantile(0.95, rate(smoltorrent_recv_duration_seconds_bucket[5m]))",
          "legendFormat": "recv p95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(smoltorrent_recv_duration_seconds_bucket[5m]))",
          "legendFormat": "recv p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 103,
      "title": "Server Health",
      "description": "API up = Prometheus can scrape port 8000; Watcher up = port 8001 reachable. Both must be 1 for the cluster to be fully operational.",
      "type": "stat",
      "gridPos": {
        "y": 21,
        "x": 12,
        "w": 12,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "up{job=\"smoltorrent-api\"}",
          "legendFormat": "API"
        },
        {
          "expr": "up{job=\"smoltorrent-watcher\"}",
          "legendFormat": "Watcher"
        }
      ],
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "horizontal",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 0
                },
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "noValue": "NO DATA"
        }
      }
    },
    {
      "id": 3,
      "title": "Transfer Errors by Worker",
      "description": "Error rate per worker rank. A rank that keeps erroring = flaky Pi or dead port.",
      "type": "timeseries",
      "gridPos": {
        "y": 29,
        "x": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(smoltorrent_transfer_errors_total[5m])",
          "legendFormat": "rank {{rank}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Operations",
      "description": "Cumulative store and gather operations (counter \u2014 never resets).",
      "type": "timeseries",
      "gridPos": {
        "y": 29,
        "x": 8,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smoltorrent_store_operations_total",
          "legendFormat": "stores"
        },
        {
          "expr": "smoltorrent_gather_operations_total",
          "legendFormat": "gathers"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "drawStyle": "line",
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 5,
      "title": "Avg Latency (ms)",
      "description": "Rolling average send and receive latency per message.",
      "type": "timeseries",
      "gridPos": {
        "y": 29,
        "x": 16,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smoltorrent_avg_send_latency_ms",
          "legendFormat": "send avg ms"
        },
        {
          "expr": "smoltorrent_avg_recv_latency_ms",
          "legendFormat": "recv avg ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Buffer Size (KB)",
      "description": "Average and max TCP message buffer size. Sudden spike = unusually large checkpoint.",
      "type": "timeseries",
      "gridPos": {
        "y": 36,
        "x": 0,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smoltorrent_avg_buffer_size_kb",
          "legendFormat": "avg buf KB"
        },
        {
          "expr": "smoltorrent_max_buffer_size_kb",
          "legendFormat": "max buf KB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "kbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Bytes Transferred",
      "description": "Cumulative bytes sent and received over TCP.",
      "type": "timeseries",
      "gridPos": {
        "y": 36,
        "x": 12,
        "w": 12,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "smoltorrent_bytes_sent_total / 1024 / 1024",
          "legendFormat": "sent MB"
        },
        {
          "expr": "smoltorrent_bytes_recv_total / 1024 / 1024",
          "legendFormat": "recv MB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 21,
      "title": "CPU Usage (%)",
      "description": "Overall CPU utilisation across all cores (100% = 1 core fully busy).",
      "type": "timeseries",
      "gridPos": {
        "y": 43,
        "x": 0,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{job=\"node\",mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Memory Usage",
      "description": "Active + wired memory vs total. macOS does not report a single 'used' counter; active+wired is the closest equivalent.",
      "type": "timeseries",
      "gridPos": {
        "y": 43,
        "x": 8,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(node_memory_active_bytes{job=\"node\"} + node_memory_wired_bytes{job=\"node\"}) / 1024 / 1024 / 1024",
          "legendFormat": "used GB"
        },
        {
          "expr": "node_memory_total_bytes{job=\"node\"} / 1024 / 1024 / 1024",
          "legendFormat": "total GB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 23,
      "title": "Disk Free \u2014 / (root)",
      "description": "Available bytes on the root APFS volume.",
      "type": "timeseries",
      "gridPos": {
        "y": 43,
        "x": 16,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_filesystem_avail_bytes{job=\"node\",mountpoint=\"/\"} / 1024 / 1024 / 1024",
          "legendFormat": "free GB"
        },
        {
          "expr": "node_filesystem_size_bytes{job=\"node\",mountpoint=\"/\"} / 1024 / 1024 / 1024",
          "legendFormat": "total GB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decgbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 24,
      "title": "Disk I/O (MB/s)",
      "description": "Read and write throughput on disk0.",
      "type": "timeseries",
      "gridPos": {
        "y": 49,
        "x": 0,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "rate(node_disk_read_bytes_total{job=\"node\",device=\"disk0\"}[1m]) / 1024 / 1024",
          "legendFormat": "read MB/s"
        },
        {
          "expr": "rate(node_disk_written_bytes_total{job=\"node\",device=\"disk0\"}[1m]) / 1024 / 1024",
          "legendFormat": "write MB/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 25,
      "title": "System Load",
      "description": "1 / 5 / 15 minute load average.",
      "type": "timeseries",
      "gridPos": {
        "y": 49,
        "x": 8,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_load1{job=\"node\"}",
          "legendFormat": "1m"
        },
        {
          "expr": "node_load5{job=\"node\"}",
          "legendFormat": "5m"
        },
        {
          "expr": "node_load15{job=\"node\"}",
          "legendFormat": "15m"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 26,
      "title": "Swap Used",
      "description": "macOS swap usage. Non-zero means memory pressure is causing pages to be compressed/swapped.",
      "type": "timeseries",
      "gridPos": {
        "y": 49,
        "x": 16,
        "w": 8,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "node_memory_swap_used_bytes{job=\"node\"} / 1024 / 1024",
          "legendFormat": "swap used MB"
        },
        {
          "expr": "node_memory_compressed_bytes{job=\"node\"} / 1024 / 1024",
          "legendFormat": "compressed MB"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Cluster Logs",
      "description": "All logs from master (API, watcher) and Pi workers in one stream.",
      "type": "logs",
      "gridPos": {
        "y": 55,
        "x": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{job=\"smoltorrent\"}",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending"
      }
    }
  ],
  "timezone": "browser"
}